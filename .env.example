# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID.
# The bot will ONLY respond to this user.
# Find your ID by messaging @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=your_telegram_user_id

# --- Encryption key (required) ---
# Used to encrypt Garmin passwords and WHOOP tokens stored in the DB.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this invalidates all existing encrypted data in the DB.
SECRET_KEY=generate_a_random_64_char_hex_string_here

# --- Garmin Connect ---
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# --- WHOOP API (OAuth 2.0) ---
# Register your app at https://developer.whoop.com
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=https://your-domain.com/whoop/callback

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./health_bot.db
